# Copy this file to ".env" for local dev, or set these as variables in Railway.
#
# AI generation is OPTIONAL. The app works as a full template editor with NO key.
# Set ANTHROPIC_API_KEY to enable the "Generate with AI" button.
# Get a key at https://console.anthropic.com/

# ANTHROPIC_API_KEY=sk-ant-...

# Optional: model used for AI generation. Defaults to claude-sonnet-4-6.
# CLAUDE_MODEL=claude-sonnet-4-6

# Access gate (STRONGLY recommended on a public deploy).
# If APP_PASSWORD is set, the whole app requires HTTP Basic login — this stops
# strangers from triggering the paid "Generate with AI" route. Leave unset to
# keep the app open (e.g. for local dev or a forked editor-only instance).
# APP_PASSWORD=choose-a-long-random-passphrase
# APP_USER=admin

# Optional: port (Railway sets this automatically).
# PORT=3000
